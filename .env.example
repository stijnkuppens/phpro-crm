# ── Project ──────────────────────────────────────
PROJECT_NAME=my-app
NEXT_PUBLIC_APP_NAME="My App"
NEXT_PUBLIC_DEMO_MODE=true

# ── Ports ───────────────────────────────────────
KONG_HTTP_PORT=8000
POSTGRES_EXPOSED_PORT=5432
STUDIO_PORT=3001

# ── Supabase URLs ────────────────────────────────
SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000

# ── JWT / Auth Keys ─────────────────────────────
JWT_SECRET=<generated>
JWT_EXP=3600
ANON_KEY=<generated>
SERVICE_ROLE_KEY=<generated>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<generated>
SUPABASE_SERVICE_ROLE_KEY=<generated>

# ── Postgres ─────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=<generated>

# ── Auth (GoTrue) ────────────────────────────────
SITE_URL=http://localhost:3000
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMTP_ADMIN_EMAIL=admin@example.com
GOTRUE_SMTP_HOST=inbucket
GOTRUE_SMTP_PORT=2500
GOTRUE_SMTP_SENDER_NAME=MyApp

# ── Realtime ─────────────────────────────────────
SECRET_KEY_BASE=<generated>

# ── Studio ───────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# ── Storage ──────────────────────────────────────
STORAGE_BACKEND=file
GLOBAL_S3_BUCKET=stub
REGION=local
STORAGE_TENANT_ID=stub
S3_PROTOCOL_ACCESS_KEY_ID=<generated>
S3_PROTOCOL_ACCESS_KEY_SECRET=<generated>
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ── PostgREST ────────────────────────────────────
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ── Misc Secrets ─────────────────────────────────
VAULT_ENC_KEY=<generated>
PG_META_CRYPTO_KEY=<generated>
LOGFLARE_API_KEY=<generated>

# ── Webhooks ─────────────────────────────────────
WEBHOOK_SECRET=<generated>
